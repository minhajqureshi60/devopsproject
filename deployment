pipeline {
    agent any

    parameters {
        string(
            name: 'IMAGE_TAG',
            defaultValue: 'latest',
            description: 'Docker image tag to deploy from JFrog'
        )
    }

    environment {
        // Docker and curl paths for macOS Jenkins
        PATH = "/Applications/Docker.app/Contents/Resources/bin:/usr/local/bin:/opt/homebrew/bin:${env.PATH}"

        // Use the same registry address used by the build pipeline
        JFROG_REGISTRY   = 'localhost:8082'
        JFROG_REPOSITORY = 'docker-local'

        IMAGE_NAME    = 'nginx-demo'
        CONTAINER_NAME = 'nginx-demo'
        HOST_PORT      = '8080'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.IMAGE_TAG?.trim()) {
                        error('IMAGE_TAG parameter cannot be empty.')
                    }

                    env.FULL_IMAGE = "${env.JFROG_REGISTRY}/${env.JFROG_REPOSITORY}/${env.IMAGE_NAME}:${params.IMAGE_TAG}"
                }

                echo "Image selected for deployment:"
                echo "${env.FULL_IMAGE}"
            }
        }

        stage('Verify Environment') {
            steps {
                sh '''
                    set -e

                    echo "Jenkins user:"
                    whoami

                    echo "Docker executable:"
                    which docker

                    echo "Docker version:"
                    docker --version

                    echo "Checking Docker daemon:"
                    docker info > /dev/null

                    echo "Checking JFrog availability:"
                    curl --fail --silent --show-error \
                      "http://$JFROG_REGISTRY/artifactory/api/system/ping"

                    echo ""
                    echo "Docker and JFrog are available."
                '''
            }
        }

        stage('Login to JFrog') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'jfrog-docker-credentials',
                        usernameVariable: 'JFROG_USERNAME',
                        passwordVariable: 'JFROG_PASSWORD'
                    )
                ]) {
                    sh '''
                        set -e

                        echo "$JFROG_PASSWORD" | docker login \
                          "$JFROG_REGISTRY" \
                          --username "$JFROG_USERNAME" \
                          --password-stdin
                    '''
                }
            }
        }

        stage('Pull Docker Image') {
            steps {
                sh '''
                    set -e

                    echo "Pulling image from JFrog:"
                    echo "$FULL_IMAGE"

                    docker pull "$FULL_IMAGE"
                '''
            }
        }

        stage('Stop Existing Container') {
            steps {
                sh '''
                    echo "Checking for an existing container..."

                    if docker ps -a \
                        --format '{{.Names}}' |
                        grep -qx "$CONTAINER_NAME"; then

                        echo "Removing existing container: $CONTAINER_NAME"
                        docker rm -f "$CONTAINER_NAME"
                    else
                        echo "No existing container found."
                    fi
                '''
            }
        }

        stage('Deploy Nginx Container') {
            steps {
                sh '''
                    set -e

                    echo "Deploying container:"
                    echo "Container name: $CONTAINER_NAME"
                    echo "Image: $FULL_IMAGE"
                    echo "Port: $HOST_PORT:80"

                    docker run -d \
                      --name "$CONTAINER_NAME" \
                      --restart unless-stopped \
                      -p "$HOST_PORT:80" \
                      --label "jenkins-job=$JOB_NAME" \
                      --label "jenkins-build=$BUILD_NUMBER" \
                      --label "image-tag=$IMAGE_TAG" \
                      "$FULL_IMAGE"
                '''
            }
        }

        stage('Validate Deployment') {
            steps {
                sh '''
                    set -e

                    echo "Waiting for Nginx to become available..."

                    ATTEMPT=1
                    MAX_ATTEMPTS=10

                    while [ "$ATTEMPT" -le "$MAX_ATTEMPTS" ]; do
                        echo "Health-check attempt $ATTEMPT of $MAX_ATTEMPTS"

                        if curl --fail --silent \
                            "http://localhost:$HOST_PORT" \
                            > /tmp/nginx-response.html; then

                            echo "Nginx responded successfully."
                            cat /tmp/nginx-response.html
                            exit 0
                        fi

                        sleep 3
                        ATTEMPT=$((ATTEMPT + 1))
                    done

                    echo "Nginx failed the deployment validation."
                    echo "Container status:"
                    docker ps -a --filter "name=$CONTAINER_NAME"

                    echo "Container logs:"
                    docker logs "$CONTAINER_NAME" || true

                    exit 1
                '''
            }
        }

        stage('Deployment Information') {
            steps {
                sh '''
                    echo "============================================"
                    echo "Deployment completed successfully"
                    echo "Image:     $FULL_IMAGE"
                    echo "Container: $CONTAINER_NAME"
                    echo "Website:   http://localhost:$HOST_PORT"
                    echo "============================================"

                    docker ps --filter "name=$CONTAINER_NAME"
                '''
            }
        }
    }

    post {
        success {
            echo "Nginx deployment completed successfully."
            echo "Open: http://localhost:${env.HOST_PORT}"
        }

        failure {
            echo 'Nginx deployment failed.'

            sh '''
                echo "Current container status:"
                docker ps -a --filter "name=$CONTAINER_NAME" || true

                echo "Container logs:"
                docker logs "$CONTAINER_NAME" || true
            '''
        }

        always {
            sh '''
                echo "Logging out from JFrog:"
                docker logout "$JFROG_REGISTRY" || true
            '''
        }
    }
}
